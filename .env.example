# Alpaca paper-trading credentials (read-only usage in this project — no orders are submitted)
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_API_SECRET=your_alpaca_api_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Shariah-compliant ETF whose holdings define the Eligible Universe
ETF_SYMBOL=SPUS

# Number of top-ranked stocks in the target Portfolio
TOP_N=20

# Optional: comma-separated ETFs to union for the Eligible Universe (defaults to ETF_SYMBOL + HLAL)
# ETF_SYMBOLS=SPUS,HLAL

# Optional: max fraction of the Portfolio from a single GICS sector (default 0.20)
# SECTOR_CAP=0.20

# Qwen Cloud (OpenAI-compatible)
QWEN_API_KEY=your_qwen_api_key
